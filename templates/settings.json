{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/time.sh",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/temporal-state.py",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/temporal-routing.py",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/temporal-routing-tracker.py",
            "timeout": 2000
          }
        ]
      }
    ]
  }
}
